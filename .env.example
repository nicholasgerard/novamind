# NovaMind agent demo — environment reference. Copy to .env (gitignored)
# and fill in only what you need. The agent reads this file at local
# runtime via apps/agent/src/load-env.ts. The web Cloudflare build script
# (scripts/web-cloudflare.mjs) masks every value below so that only the
# explicitly web-safe values reach the OpenNext bundle.

# ─── Models ───────────────────────────────────────────────────────────
# Anthropic / Claude — drives the Agent SDK literature orchestrator, the
# scoped structured model tools, the prompt improver, and Haiku judges.
ANTHROPIC_API_KEY=

# OpenAI — used by:
#   - the embedding pipeline (text-embedding-3-large), in parallel with Voyage
#   - the single-turn-structured eval axis (GPT-5.1 alongside Claude)
OPENAI_API_KEY=

# Voyage — primary embedding provider for the corpus and live retrieval.
VOYAGE_API_KEY=

# ─── Tools / data sources ─────────────────────────────────────────────
# PubMed E-utilities ingestion (packages/corpus). NCBI_API_KEY is
# optional but recommended — without it, the public rate limit is ~3 req/s.
# NCBI_TOOL + NCBI_EMAIL identify the client per NCBI guidance.
NCBI_API_KEY=
NCBI_TOOL=novamind-corpus
NCBI_EMAIL=

# Braintrust — when set, every eval CLI run uploads to the `novamind`
# project as a fresh experiment alongside the local JSON output.
BRAINTRUST_API_KEY=

# ─── Cloudflare deploy ────────────────────────────────────────────────
# Used by `pnpm --filter @novamind/{web,agent,corpus} ...:cf` plus the
# GitHub Actions workflows.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# R2 corpus storage. The corpus uploader prefers CLOUDFLARE_API_TOKEN +
# Wrangler; the S3-compatible keys are an optional fallback. R2_BUCKET
# defaults to "novamind-corpus". Set R2_SKIP_DEV_URL=true when you intend
# to front the bucket with a custom domain.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=novamind-corpus
R2_SKIP_DEV_URL=false

# ─── Runtime corpus location ──────────────────────────────────────────
# Production fetches the corpus + embeddings from these R2 URLs at boot.
# Stage 6 also fetches the ClinicalTrials.gov snapshot from NOVAMIND_TRIALS_URL.
# Local development can fall back to gitignored filesystem data and finally to
# small offline fixtures.
# `pnpm --filter @novamind/corpus upload-r2` prints these values.
NOVAMIND_PAPERS_URL=
NOVAMIND_VOYAGE_EMBEDDINGS_URL=
NOVAMIND_OPENAI_EMBEDDINGS_URL=
NOVAMIND_TRIALS_URL=

# Override where the agent looks for local corpus files (dev / Docker
# tweaks). Default: internal/corpus/data at the repository root.
NOVAMIND_CORPUS_DIR=

# Override where the agent looks for local ClinicalTrials.gov data.
# Default: internal/clinical-trials/data at the repository root.
NOVAMIND_TRIALS_DIR=

# Override where eval CLI scripts write local JSON run artifacts.
# Default: internal/eval/runs at the repository root.
NOVAMIND_EVAL_RUNS_DIR=

# ─── Containers + Workers tunables ────────────────────────────────────
# Cloudflare Container instance name. Keep stable for the main demo runtime;
# use a different value only when you intentionally want an isolated warm
# runtime, such as staging or a rehearsal environment.
NOVAMIND_AGENT_INSTANCE=demo-primary

# Web → agent base URL for local development only. Production must use the
# AGENT_SERVICE Cloudflare service binding and fails closed if it is missing.
AGENT_BASE_URL=http://localhost:8787

# Local development auth bypass. Package dev scripts set this automatically;
# leave unset in production and CI deploy environments.
NOVAMIND_ALLOW_LOCAL_AUTH=
NEXT_PUBLIC_NOVAMIND_ALLOW_LOCAL_AUTH=

# Production smoke-test origins. These are consumed by scripts/smoke.mjs and
# GitHub Actions; runtime web → agent traffic still uses service bindings.
WEB_ORIGIN=https://novamind.personal-901.workers.dev
AGENT_ORIGIN=https://novamind-agent.personal-901.workers.dev
# Optional Cloudflare Access service-token credentials for direct production
# smoke tests against an edge-protected agent hostname.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# Cloudflare Access — gates paid / stateful demo actions while keeping the
# presentation itself viewable. Protect web `/api/*` and public agent run
# routes with Access; the Workers verify Access JWTs and enforce this domain
# when both Access values are set.
NOVAMIND_ACCESS_EMAIL_DOMAIN=thebkapp.co
# Browser-visible copy of the same domain for the access modal. Keep this in
# sync with NOVAMIND_ACCESS_EMAIL_DOMAIN when changing the allowed domain.
NEXT_PUBLIC_NOVAMIND_ACCESS_EMAIL_DOMAIN=thebkapp.co
CLOUDFLARE_ACCESS_AUD=
CLOUDFLARE_ACCESS_TEAM_DOMAIN=

# Shared secret for web Worker → agent Worker requests. Generate with:
#   openssl rand -hex 32
# Store the same value in GitHub Actions and both Cloudflare Workers.
NOVAMIND_AGENT_INTERNAL_TOKEN=

# Exact browser origin allowed by the public agent CORS and mutation-origin
# policies. Do not include a trailing slash. Server-to-server service binding
# calls do not rely on CORS, but this prevents accidental credentialed browser
# access from arbitrary origins.
NOVAMIND_WEB_ORIGIN=https://novamind.personal-901.workers.dev

# Fixture-mode toggle for deterministic offline demos. When true, the
# agent ignores R2 / local corpus artifacts and uses the offline fixture.
DEMO_FIXTURE_MODE=false

# Live-demo verifier check. When true, the agent-side claim extraction tool
# appends one unsupported claim after the extractor model returns, labels it
# only in the UI stream, and keeps demo metadata out of model/tool handoffs.
INJECT_UNVERIFIED_CLAIM=true

# Stream the Claude Agent SDK's stderr to the agent's process stderr —
# useful when debugging the SDK's binary spawn or tool routing.
NOVAMIND_AGENT_SDK_DEBUG=false
NOVAMIND_AGENT_SDK_DEBUG_FILE=

# Agent SDK startup and stream watchdogs. Startup uses Agent SDK `startup()`
# to prepare one-shot warm profiles; live routes fall back to cold `query()`
# if a warm profile is unavailable.
NOVAMIND_AGENT_SDK_STARTUP_TIMEOUT_MS=90000
NOVAMIND_AGENT_SDK_COLD_FIRST_MESSAGE_TIMEOUT_MS=90000
NOVAMIND_AGENT_SDK_WARM_FIRST_MESSAGE_TIMEOUT_MS=15000
NOVAMIND_AGENT_SDK_IDLE_TIMEOUT_MS=180000
NOVAMIND_AGENT_SDK_LIVE_STARTUP_WAIT_MS=2000
# After Stage 6 builds all four charts, wait this long for the Agent SDK final
# structured report before assembling the final report from the completed chart
# set so the browser does not hang on the last step.
NOVAMIND_DATA_VIZ_FINAL_REPORT_GRACE_MS=10000
API_TIMEOUT_MS=120000
CLAUDE_CODE_MAX_RETRIES=2
CLAUDE_ENABLE_STREAM_WATCHDOG=1
CLAUDE_STREAM_IDLE_TIMEOUT_MS=300000
CLAUDE_ASYNC_AGENT_STALL_TIMEOUT_MS=

# Optional: request one-hour prompt-cache writes. This can improve repeated
# demo startup/run economics when prompts are reused after five-minute gaps,
# but cache writes cost more, so leave it blank unless that tradeoff is useful.
ENABLE_PROMPT_CACHING_1H=

# Literature orchestrator Agent SDK tuning. Defaults are optimized for the
# bounded demo path: low effort, disabled extended thinking, disabled tool
# search, no auto-loaded Claude Code memory, and an isolated SDK runtime dir.
# Sonnet routes support low, medium, high, and max; xhigh is passed only to
# models that support it.
NOVAMIND_ORCHESTRATOR_EFFORT=low
NOVAMIND_ORCHESTRATOR_THINKING=disabled
CLAUDE_CODE_DISABLE_AUTO_MEMORY=1
ENABLE_TOOL_SEARCH=false

# Optional Agent SDK runtime isolation overrides. Leave blank unless your
# container needs a different writable path. The agent defaults to
# /tmp/novamind-claude-agent-sdk and derives profile-specific cwd/config paths
# from it for the literature and data-viz SDK profiles.
NOVAMIND_CLAUDE_RUNTIME_DIR=
NOVAMIND_CLAUDE_RUNTIME_CWD=
NOVAMIND_CLAUDE_CONFIG_DIR=

# Optional Agent SDK OpenTelemetry forwarding. Configure these only when you
# have an OTLP collector. Cold queries include live run IDs in resource
# attributes; warm queries use startup-time profile attributes and correlate
# to live runs through application timing logs.
CLAUDE_CODE_ENABLE_TELEMETRY=
CLAUDE_CODE_ENHANCED_TELEMETRY_BETA=
ENABLE_BETA_TRACING_DETAILED=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_PROTOCOL=
OTEL_TRACES_EXPORTER=
OTEL_METRICS_EXPORTER=
OTEL_LOGS_EXPORTER=

# Explicit Claude Code executable path. Usually unnecessary; the pipeline
# auto-resolves the SDK-bundled native binary on Linux.
NOVAMIND_CLAUDE_EXECUTABLE_PATH=
