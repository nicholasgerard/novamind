{
  "name": "@novamind/agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NOVAMIND_ALLOW_LOCAL_AUTH=1 tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsup",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "deploy:cf": "wrangler deploy --config wrangler.toml --env-file ../../.env --containers-rollout immediate",
    "deploy:cf:ci": "wrangler deploy --config wrangler.toml --containers-rollout immediate"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.141",
    "@hono/node-server": "^1.13.7",
    "@novamind/eval": "workspace:*",
    "@novamind/pipeline": "workspace:*",
    "@novamind/shared": "workspace:*",
    "dotenv": "^16.4.7",
    "hono": "^4.6.16",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
